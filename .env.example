# memlake configuration — copy to `.env` and fill in. `.env` is gitignored.
#
# Config is SERVICE-SCOPED: each service reads its OWN prefixed block and builds its own config
# object (no shared/`AWS_*` fallback). Services: QUERY (mlake-server serve), INDEXER
# (mlake-server index), PERF (mlake-perf). Loaded on startup via dotenvy; real env overrides the
# file; CLI flags override env. Full reference: docs/CONFIGURATION.md.

# ============================================================================
# QUERY service — mlake-server serve
# ============================================================================
MEMLAKE_QUERY_S3_BUCKET=memlake
MEMLAKE_QUERY_S3_ACCESS_KEY=
MEMLAKE_QUERY_S3_SECRET_KEY=
MEMLAKE_QUERY_S3_REGION=us-east-1
# MEMLAKE_QUERY_S3_ENDPOINT=http://localhost:9000   # set for MinIO / S3-compatible; unset ⇒ AWS S3
# MEMLAKE_QUERY_MAX_CONCURRENT=32                    # cap on in-flight query/get (flag: --max-concurrent-queries)

# ============================================================================
# INDEXER service — mlake-server index
# ============================================================================
MEMLAKE_INDEXER_S3_BUCKET=memlake
MEMLAKE_INDEXER_S3_ACCESS_KEY=
MEMLAKE_INDEXER_S3_SECRET_KEY=
MEMLAKE_INDEXER_S3_REGION=us-east-1
# MEMLAKE_INDEXER_S3_ENDPOINT=http://localhost:9000
#
# The fold auto-selects the in-RAM fold below the threshold and the bounded external-memory
# (streaming) fold at/above it. Threshold in docs; 0 forces streaming, a huge value forces in-RAM.
# MEMLAKE_INDEXER_STREAMING_THRESHOLD=4000000
#
# Per-stage RAM budget for the streaming fold (MB) — peak fold RAM, not a function of corpus size:
# MEMLAKE_INDEXER_FOLD_RESOLVE_MB=128   # Phase-1 id resolution
# MEMLAKE_INDEXER_FOLD_CLUSTER_MB=256   # cluster grouping (full item bytes)
# MEMLAKE_INDEXER_FOLD_PAYLOAD_MB=128   # payload store
# MEMLAKE_INDEXER_FOLD_INDEX_MB=96      # pk + entity + time (split three ways)
# MEMLAKE_INDEXER_FOLD_RADJ_MB=64       # reverse-adjacency (causal edges)
# MEMLAKE_INDEXER_FOLD_FTS_MB=128       # tantivy writer arena

# ============================================================================
# PERF service — mlake-perf (dev tool)
# ============================================================================
MEMLAKE_PERF_S3_BUCKET=memlake
MEMLAKE_PERF_S3_ACCESS_KEY=
MEMLAKE_PERF_S3_SECRET_KEY=
MEMLAKE_PERF_S3_REGION=us-east-1
# MEMLAKE_PERF_S3_ENDPOINT=http://localhost:9000
# MEMLAKE_PERF_TEMPORAL_SPAN=120                     # temporal query window span (synthetic units)
# MEMLAKE_PERF_STREAMING_THRESHOLD=4000000           # 0 forces the streaming fold at any scale
# MEMLAKE_PERF_FOLD_RESOLVE_MB=128  (…CLUSTER_MB, PAYLOAD_MB, INDEX_MB, RADJ_MB, FTS_MB — as INDEXER)

# ============================================================================
# Local MinIO dev preset (docker compose up -d): for each service block above, set
#   *_S3_BUCKET=memlake, *_S3_ENDPOINT=http://localhost:9000,
#   *_S3_ACCESS_KEY=memlake, *_S3_SECRET_KEY=memlake123, *_S3_REGION=us-east-1
# ============================================================================
