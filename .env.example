# memlake configuration — copy to `.env` and fill in. `.env` is gitignored.
# Loaded automatically by mlake-server and mlake-perf on startup (dotenvy).
# Real process environment always overrides these, so a deploy can set the same
# variables without editing this file.
#
# Precedence per field: the MEMLAKE_S3_* name first, then the standard AWS_* name.

# --- Bucket (required) -------------------------------------------------------
MEMLAKE_S3_BUCKET=memlake

# --- Endpoint ----------------------------------------------------------------
# Set for MinIO / any S3-compatible endpoint (dev). LEAVE UNSET for real AWS S3.
# MEMLAKE_S3_ENDPOINT=http://localhost:9000

# --- Credentials (required) --------------------------------------------------
# Standard AWS names work as-is:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# memlake-specific overrides (take precedence over the AWS_* names above):
# MEMLAKE_S3_ACCESS_KEY=
# MEMLAKE_S3_SECRET_KEY=
# MEMLAKE_S3_REGION=us-east-1

# --- Local MinIO dev preset --------------------------------------------------
# For the docker-compose MinIO, use:
#   MEMLAKE_S3_BUCKET=memlake
#   MEMLAKE_S3_ENDPOINT=http://localhost:9000
#   AWS_ACCESS_KEY_ID=memlake
#   AWS_SECRET_ACCESS_KEY=memlake123
#   AWS_REGION=us-east-1
