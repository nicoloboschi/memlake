# memlake configuration — copy to `.env` and fill in. `.env` is gitignored.
#
# Loaded automatically on startup (dotenvy) by BOTH `mlake-server` and `mlake-perf`, so any
# variable below can live here. Real process environment always overrides the file, so a
# deployment sets the same variables without editing it. CLI flags override env vars.
#
# Full reference (every var + every flag, with defaults): docs/CONFIGURATION.md

# ============================================================================
# Object store (required) — where all data lives. Read by Store::from_env().
# Precedence per field: the MEMLAKE_S3_* name first, then the standard AWS_* name.
# ============================================================================
MEMLAKE_S3_BUCKET=memlake

# Endpoint: set for MinIO / any S3-compatible endpoint. LEAVE UNSET for real AWS S3.
# MEMLAKE_S3_ENDPOINT=http://localhost:9000

# Credentials — standard AWS names work as-is:
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# memlake-specific credential overrides (take precedence over the AWS_* names above):
# MEMLAKE_S3_ACCESS_KEY=
# MEMLAKE_S3_SECRET_KEY=
# MEMLAKE_S3_REGION=us-east-1

# ============================================================================
# Query server tuning (mlake-server serve) — all optional, shown with defaults.
# Each also has a CLI flag that overrides the env var.
# ============================================================================
# Max concurrently-executing retrieval requests. Peak query memory ≈ this × per-query
# working set; excess requests queue (backpressure), they are not rejected. Flag:
# --max-concurrent-queries
# MEMLAKE_MAX_CONCURRENT_QUERIES=32

# Stable node identity, stamped on every log line. Flag: --node-id
# MEMLAKE_NODE_ID=

# ============================================================================
# Streaming-fold memory budget (mlake-server index --streaming, mlake-perf --streaming).
# Per-stage caps in MB; peak fold RAM is bounded by these, NOT by corpus size. Env-only
# (no flags). Defaults shown. See docs/CONFIGURATION.md for how the stages combine.
# ============================================================================
# MEMLAKE_FOLD_RESOLVE_MB=128   # Phase-1 id resolution (spills events)
# MEMLAKE_FOLD_CLUSTER_MB=256   # cluster grouping (full item bytes)
# MEMLAKE_FOLD_PAYLOAD_MB=128   # payload store
# MEMLAKE_FOLD_INDEX_MB=96      # pk + entity + time (split three ways)
# MEMLAKE_FOLD_RADJ_MB=64       # reverse-adjacency (causal edges)
# MEMLAKE_FOLD_FTS_MB=128       # tantivy writer arena

# ============================================================================
# Diagnostics
# ============================================================================
# Print per-phase index build timings to stderr when set to anything.
# MEMLAKE_TIMING=1

# ============================================================================
# Local MinIO dev preset (docker compose up -d) — uncomment to use instead of AWS:
#   MEMLAKE_S3_BUCKET=memlake
#   MEMLAKE_S3_ENDPOINT=http://localhost:9000
#   AWS_ACCESS_KEY_ID=memlake
#   AWS_SECRET_ACCESS_KEY=memlake123
#   AWS_REGION=us-east-1
# ============================================================================
