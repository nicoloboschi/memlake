# memlake admin UI — copy to .env.local and edit.
#
# Everything here is read SERVER-SIDE only (route handlers). None of it is
# exposed to the browser: gRPC cannot be spoken from a page, so the browser only
# ever talks to this app's own JSON endpoints.

# host:port of `mlake-server serve`. Insecure credentials are used — memlake is
# an internal, unauthenticated, east-west service.
MEMLAKE_ADDR=localhost:50051

# The contract. Loaded dynamically at runtime by @grpc/proto-loader, so the UI
# cannot drift from the .proto. A relative path is resolved against the admin/
# directory (the Next.js cwd).
MEMLAKE_PROTO_PATH=../proto/memlake/v1/memlake.proto

# Set to `off` to disable server-side query embedding entirely (no model
# download, no ~90MB cache). The query page then only offers the raw-vector and
# text-only modes.
# MEMLAKE_EMBEDDINGS=off

# Where transformers.js caches the ONNX weights. Defaults to
# node_modules/@huggingface/transformers/.cache; point it somewhere persistent
# if node_modules is disposable.
# HF_HOME=./.cache/huggingface
# TRANSFORMERS_CACHE=./.cache/transformers
